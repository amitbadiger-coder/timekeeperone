{
  "expo": {
    "name": "TimeKeeper",
    "slug": "TimeKeeper",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "timekeeper",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.newArch.timekeeper",
      "softwareKeyboardLayoutMode": "pan"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/android-icon-background.png"
    },
    "plugins": [
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/roboto.ttf",
            "./assets/fonts/myfont.ttf",
            "./assets/fonts/bungee.ttf",
            "./assets/fonts/boldonse.ttf"
          ]
        }
      ],
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/android-icon-background.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 36,
            "targetSdkVersion": 36,
            "buildToolsVersion": "36.0.0",
            "buildArchs": ["x86_64"],
            "useDayNightTheme": true
          }
        }
      ],
      [
        "./plugins/withAndroidSigning",
        {
          "storeFile": "play-store-upload-key.keystore",
          "storePassword": "dhamiroshan@2003",
          "keyAlias": "upload-key",
          "keyPassword": "dhamiroshan@2003"
        }
      ],
      [
        "react-native-android-widget",
        {
          "fonts": ["./assets/fonts/bungee.ttf"],
          "widgets": [
            {
              "name": "TimeKeeper",
              "label": "TimeKeeper Widget",
              "minWidth": "320dp",
              "minHeight": "120dp",
              "resizeMode": "horizontal|vertical",
              "targetCellWidth": 4,
              "targetCellHeight": 3,
              "description": "All Counter on your home ",
              "previewImage": "./assets/images/icon.png",
              "updatePeriodMillis": 1800000
            }
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
